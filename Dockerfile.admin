FROM node:22-alpine AS build

ARG VITE_API_URL=https://api.appbuildbox.com
ENV VITE_API_URL=$VITE_API_URL

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY apps/admin/package.json apps/admin/
COPY packages/contracts/package.json packages/contracts/
COPY packages/executors-runtime/package.json packages/executors-runtime/

RUN pnpm install --frozen-lockfile

COPY packages/contracts/src/ packages/contracts/src/
COPY packages/contracts/tsconfig.json packages/contracts/
COPY packages/executors-runtime/src/ packages/executors-runtime/src/
COPY packages/executors-runtime/tsconfig.json packages/executors-runtime/

RUN pnpm -F @support-agent/contracts build && \
    pnpm -F @support-agent/executors-runtime build

COPY apps/admin/index.html apps/admin/
COPY apps/admin/public/ apps/admin/public/
COPY apps/admin/src/ apps/admin/src/
COPY apps/admin/tsconfig.json apps/admin/
COPY apps/admin/tsconfig.app.json apps/admin/
COPY apps/admin/tsconfig.node.json apps/admin/
COPY apps/admin/vite.config.ts apps/admin/

RUN pnpm -F @support-agent/admin build

FROM nginx:alpine

COPY --from=build /app/apps/admin/dist/ /usr/share/nginx/html/

# Place the admin server block in /etc/nginx/templates/. The default nginx
# entrypoint envsubst's *.template into /etc/nginx/conf.d/ at boot, so the
# ADMIN_API_CONNECT_SRC placeholder in the CSP is resolved without an
# explicit entrypoint script. Default to "'self'" when the var is unset so
# the resulting CSP remains valid in local dev.
COPY nginx/admin.conf /etc/nginx/templates/default.conf.template

ENV NGINX_ENVSUBST_TEMPLATE_DIR=/etc/nginx/templates \
    NGINX_ENVSUBST_TEMPLATE_SUFFIX=.template \
    NGINX_ENVSUBST_OUTPUT_DIR=/etc/nginx/conf.d \
    ADMIN_API_CONNECT_SRC="'self'"

EXPOSE 8080
