{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "deep-reviewer SkillRunResult",
  "type": "object",
  "properties": {
    "delivery": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "prefixItems": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "comment"
            },
            "body": {
              "type": "string"
            }
          },
          "required": ["kind", "body"]
        }
      ]
    },
    "reportSummary": {
      "type": "string"
    },
    "loop": {
      "type": "object",
      "properties": {
        "done": {
          "type": "boolean"
        },
        "next_iteration_focus": {
          "type": "string"
        }
      },
      "required": ["done"]
    },
    "extras": {
      "type": "object"
    }
  },
  "required": ["delivery"]
}
