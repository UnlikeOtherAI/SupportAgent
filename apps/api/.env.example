DATABASE_URL=postgresql://supportagent:supportagent@localhost:5432/supportagent_dev
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-real-secret-at-least-32-chars
API_BASE_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# ── UOA SSO (optional in dev; all four must be set to offer SSO) ───────
# SSO_DOMAIN must match the public hostname that serves /.well-known/jwks.json
# and /v1/auth/sso-config (i.e. the API hostname in prod).
#SSO_DOMAIN=api.appbuildbox.com
#UOA_CONFIG_SIGNING_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
#UOA_JWK_KID=supportagent-2026-04
#UOA_CONTACT_EMAIL=ops@example.com
# Populated after UOA approves the integration and the claim link is consumed.
#UOA_CLIENT_SECRET=uoa_sec_...
