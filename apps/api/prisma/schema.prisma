// ──────────────────────────────────────────────
// Support Agent — Prisma Schema
// ──────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────

enum WorkflowType {
  triage
  build
  merge
  review
}

enum WorkflowRunStatus {
  queued
  blocked
  dispatched
  running
  awaiting_review
  awaiting_human
  succeeded
  failed
  canceled
  lost
}

enum WorkItemKind {
  issue
  review_target
}

enum OutputVisibility {
  full
  redacted
  metadata_only
}

enum ConnectorDirection {
  inbound
  outbound
  both
}

enum IntakeMode {
  webhook
  polling
  manual
}

enum ConnectionMode {
  direct
  reverse_connected
}

enum RuntimeMode {
  worker
  gateway
}

enum TriggerActionType {
  create_workflow_run
  notify
  block
}

enum DeliveryStatus {
  pending
  sent
  failed
  skipped
}

enum ActionDeliveryStatus {
  pending
  succeeded
  failed
  skipped
}

enum ReviewDecision {
  approved
  rejected
  needs_revision
  inconclusive
}

enum SkillRole {
  SYSTEM
  COMPLEMENTARY
}

enum SkillSource {
  BUILTIN
  USER
}

enum ExecutorSource {
  BUILTIN
  USER
}

enum AuditAction {
  created
  updated
  deleted
  triggered
  dispatched
  completed
  failed
  canceled
}

// ─── Models ──────────────────────────────────

// 1. PlatformType
model PlatformType {
  id               String   @id @default(uuid())
  key              String   @unique
  displayName      String
  supportsWebhook  Boolean
  supportsPolling  Boolean
  supportsInbound  Boolean
  supportsOutbound Boolean
  description      String   @default("")
  category         String   @default("issue-tracker")
  createdAt        DateTime @default(now())

  connectors Connector[]

  @@map("platform_types")
}

// 2. Connector
model Connector {
  id                     String             @id @default(uuid())
  tenantId               String
  platformTypeId         String
  name                   String
  direction              ConnectorDirection
  configuredIntakeMode   IntakeMode
  effectiveIntakeMode    IntakeMode
  isEnabled              Boolean            @default(true)
  webhookSecret          String?
  pollingIntervalSeconds Int?
  apiBaseUrl             String?
  capabilities           Json?
  taxonomyConfig         Json?
  imageDescriptionPolicy String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  platformType          PlatformType              @relation(fields: [platformTypeId], references: [id])
  endpoints             ConnectorEndpoint[]
  connectorCapabilities ConnectorCapability[]
  taxonomyCaches        ConnectorTaxonomyCache[]
  scopeMappings         ConnectorScopeMapping[]
  connectionSecrets     ConnectionSecret[]
  repositoryMappings    RepositoryMapping[]
  routingRules          RoutingRule[]
  outboundDestinations  OutboundDestination[]
  commentThreads        ConnectorCommentThread[]
  inboundWorkItems      InboundWorkItem[]
  scenarioBindings      WorkflowScenarioBinding[]

  @@index([tenantId])
  @@index([platformTypeId])
  @@map("connectors")
}

// 3. ConnectorEndpoint
model ConnectorEndpoint {
  id             String    @id @default(uuid())
  connectorId    String
  endpointType   String
  url            String
  isActive       Boolean   @default(true)
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())

  connector Connector @relation(fields: [connectorId], references: [id])

  @@index([connectorId])
  @@map("connector_endpoints")
}

// 4. ConnectorCapability
model ConnectorCapability {
  id            String   @id @default(uuid())
  connectorId   String
  capabilityKey String
  isSupported   Boolean
  discoveredAt  DateTime @default(now())
  metadata      Json?

  connector Connector @relation(fields: [connectorId], references: [id])

  @@unique([connectorId, capabilityKey])
  @@index([connectorId])
  @@map("connector_capabilities")
}

// 5. ConnectorTaxonomyCache
model ConnectorTaxonomyCache {
  id           String   @id @default(uuid())
  connectorId  String
  taxonomyType String
  externalId   String
  label        String
  parentId     String?
  metadata     Json?
  cachedAt     DateTime @default(now())

  connector Connector @relation(fields: [connectorId], references: [id])

  @@index([connectorId])
  @@map("connector_taxonomy_caches")
}

// 6. ConnectorScopeMapping
model ConnectorScopeMapping {
  id              String   @id @default(uuid())
  connectorId     String
  scopeType       String
  externalScopeId String
  label           String
  metadata        Json?
  createdAt       DateTime @default(now())

  connector Connector @relation(fields: [connectorId], references: [id])

  @@index([connectorId])
  @@map("connector_scope_mappings")
}

// 7. ConnectionSecret
model ConnectionSecret {
  id             String    @id @default(uuid())
  connectorId    String
  secretType     String
  encryptedValue String
  maskedHint     String?
  createdAt      DateTime  @default(now())
  rotatedAt      DateTime?

  connector Connector @relation(fields: [connectorId], references: [id])

  @@index([connectorId])
  @@map("connection_secrets")
}

// 8. RepositoryMapping
model RepositoryMapping {
  id                     String   @id @default(uuid())
  tenantId               String
  connectorId            String
  repositoryUrl          String
  defaultBranch          String   @default("main")
  executionProfileId     String?
  orchestrationProfileId String?
  reviewProfileId        String?
  dependencyPolicy       Json?
  notificationBindings   Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  connector           Connector                     @relation(fields: [connectorId], references: [id])
  executionProfile    ExecutionProfile?             @relation(fields: [executionProfileId], references: [id])
  routingRules        RoutingRule[]
  inboundWorkItems    InboundWorkItem[]
  workflowRuns        WorkflowRun[]
  featureDeliveryRuns FeatureDeliveryRun[]
  scenarioBindings    WorkflowScenarioBinding[]
  eventSubscriptions  RepositoryEventSubscription[]

  @@index([tenantId])
  @@index([connectorId])
  @@index([executionProfileId])
  @@map("repository_mappings")
}

// 9. RoutingRule
model RoutingRule {
  id                  String   @id @default(uuid())
  tenantId            String
  connectorId         String?
  repositoryMappingId String?
  priority            Int
  conditions          Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  connector         Connector?         @relation(fields: [connectorId], references: [id])
  repositoryMapping RepositoryMapping? @relation(fields: [repositoryMappingId], references: [id])
  targets           RoutingTarget[]

  @@index([tenantId])
  @@index([connectorId])
  @@index([repositoryMappingId])
  @@map("routing_rules")
}

// 10. RoutingTarget
model RoutingTarget {
  id                    String   @id @default(uuid())
  routingRuleId         String
  outboundDestinationId String
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())

  routingRule         RoutingRule         @relation(fields: [routingRuleId], references: [id])
  outboundDestination OutboundDestination @relation(fields: [outboundDestinationId], references: [id])

  @@index([routingRuleId])
  @@index([outboundDestinationId])
  @@map("routing_targets")
}

// 11. TriggerPolicy
model TriggerPolicy {
  id           String       @id @default(uuid())
  tenantId     String
  name         String
  workflowType WorkflowType
  isEnabled    Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  conditions        TriggerCondition[]
  actions           TriggerAction[]
  workflowScenarios WorkflowScenario[]

  @@index([tenantId])
  @@map("trigger_policies")
}

// 12. TriggerCondition
model TriggerCondition {
  id              String   @id @default(uuid())
  triggerPolicyId String
  conditionType   String
  field           String
  operator        String
  value           String
  createdAt       DateTime @default(now())

  triggerPolicy TriggerPolicy @relation(fields: [triggerPolicyId], references: [id])

  @@index([triggerPolicyId])
  @@map("trigger_conditions")
}

// 13. TriggerAction
model TriggerAction {
  id              String            @id @default(uuid())
  triggerPolicyId String
  actionType      TriggerActionType
  config          Json
  createdAt       DateTime          @default(now())

  triggerPolicy TriggerPolicy @relation(fields: [triggerPolicyId], references: [id])

  @@index([triggerPolicyId])
  @@map("trigger_actions")
}

// 14. WorkflowScenario
model WorkflowScenario {
  id                     String       @id @default(uuid())
  tenantId               String
  key                    String
  displayName            String
  workflowType           WorkflowType
  isEnabled              Boolean      @default(true)
  triggerPolicyId        String?
  dependencyPolicyConfig Json?
  executionProfileId     String?
  orchestrationProfileId String?
  reviewProfileId        String?
  prAllowed              Boolean      @default(false)
  prIntent               String?
  mergeAllowed           Boolean      @default(false)
  notificationConfig     Json?
  distributionConfig     Json?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  triggerPolicy    TriggerPolicy?            @relation(fields: [triggerPolicyId], references: [id])
  executionProfile ExecutionProfile?         @relation(fields: [executionProfileId], references: [id])
  bindings         WorkflowScenarioBinding[]
  steps            WorkflowScenarioStep[]
  workflowRuns     WorkflowRun[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([triggerPolicyId])
  @@index([executionProfileId])
  @@map("workflow_scenarios")
}

// 15. WorkflowScenarioBinding
model WorkflowScenarioBinding {
  id                  String   @id @default(uuid())
  scenarioId          String
  connectorId         String?
  repositoryMappingId String?
  priority            Int
  createdAt           DateTime @default(now())

  scenario          WorkflowScenario   @relation(fields: [scenarioId], references: [id])
  connector         Connector?         @relation(fields: [connectorId], references: [id])
  repositoryMapping RepositoryMapping? @relation(fields: [repositoryMappingId], references: [id])

  @@index([scenarioId])
  @@index([connectorId])
  @@index([repositoryMappingId])
  @@map("workflow_scenario_bindings")
}

// 16. WorkflowScenarioStep
model WorkflowScenarioStep {
  id         String   @id @default(uuid())
  scenarioId String
  stepOrder  Int
  stepType   String
  config     Json
  createdAt  DateTime @default(now())

  scenario WorkflowScenario @relation(fields: [scenarioId], references: [id])

  @@index([scenarioId])
  @@map("workflow_scenario_steps")
}

// 17. InboundWorkItem
model InboundWorkItem {
  id                  String       @id @default(uuid())
  connectorInstanceId String
  platformType        String
  workItemKind        WorkItemKind
  externalItemId      String
  externalUrl         String?
  title               String
  body                String?      @db.Text
  priority            String?
  severity            String?
  status              String?
  taxonomy            Json?
  attachments         Json?
  comments            Json?
  dependencyRefs      Json?
  sourcePayloadRef    String?
  repositoryMappingId String?
  dedupeKey           String?
  repositoryRef       String?
  baseRef             String?
  headRef             String?
  commitRange         String?
  diffRef             String?
  reviewTargetType    String?
  reviewTargetNumber  Int?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  connector                Connector                 @relation(fields: [connectorInstanceId], references: [id])
  repositoryMapping        RepositoryMapping?        @relation(fields: [repositoryMappingId], references: [id])
  workflowRuns             WorkflowRun[]
  commentThreads           ConnectorCommentThread[]
  dependenciesFrom         WorkItemDependency[]      @relation("DependencySource")
  dependenciesTo           WorkItemDependency[]      @relation("DependencyTarget")
  dependencySnapshots      DependencySnapshot[]
  dependencyOverrides      DependencyOverride[]
  featureDeliveryWorkItems FeatureDeliveryWorkItem[]

  @@index([connectorInstanceId])
  @@index([repositoryMappingId])
  @@index([dedupeKey])
  @@map("inbound_work_items")
}

// 18. WorkflowRun
model WorkflowRun {
  id                       String            @id @default(uuid())
  tenantId                 String
  workflowType             WorkflowType
  workItemId               String
  repositoryMappingId      String
  executionProfileId       String?
  orchestrationProfileId   String?
  reviewProfileId          String?
  workflowScenarioId       String?
  parentWorkflowRunId      String?
  status                   WorkflowRunStatus @default(queued)
  currentStage             String?
  attemptNumber            Int               @default(1)
  blockedReason            String?
  providerExecutionRef     String?
  acceptedDispatchAttempt  String?
  resolvedExecutorRevision String?
  resolvedSkillRevisions   Json?
  progressCommentId        String?
  lastProgressEditAt       DateTime?
  createdAt                DateTime          @default(now())
  startedAt                DateTime?
  completedAt              DateTime?
  updatedAt                DateTime          @updatedAt

  workItem               InboundWorkItem           @relation(fields: [workItemId], references: [id])
  repositoryMapping      RepositoryMapping         @relation(fields: [repositoryMappingId], references: [id])
  executionProfile       ExecutionProfile?         @relation(fields: [executionProfileId], references: [id])
  workflowScenario       WorkflowScenario?         @relation(fields: [workflowScenarioId], references: [id])
  parentWorkflowRun      WorkflowRun?              @relation("WorkflowRunChildren", fields: [parentWorkflowRunId], references: [id])
  childWorkflowRuns      WorkflowRun[]             @relation("WorkflowRunChildren")
  logEvents              WorkflowLogEvent[]
  findings               Finding[]
  deliveryAttempts       OutboundDeliveryAttempt[]
  actionOutputs          ActionOutput[]
  actionDeliveryAttempts ActionDeliveryAttempt[]
  dispatches             WorkerDispatch[]
  reviews                WorkflowRunReview[]
  conversationThreads    ConversationThread[]

  @@index([tenantId])
  @@index([workItemId])
  @@index([repositoryMappingId])
  @@index([executionProfileId])
  @@index([workflowScenarioId])
  @@index([parentWorkflowRunId])
  @@index([status])
  @@map("workflow_runs")
}

// 19. WorkflowLogEvent
model WorkflowLogEvent {
  id            String   @id @default(uuid())
  workflowRunId String
  timestamp     DateTime @default(now())
  streamType    String
  stage         String?
  message       String   @db.Text
  hostMeta      Json?
  createdAt     DateTime @default(now())

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id])

  @@index([workflowRunId])
  @@map("workflow_log_events")
}

// 20. Finding
model Finding {
  id                    String   @id @default(uuid())
  workflowRunId         String
  summary               String   @db.Text
  rootCauseHypothesis   String?  @db.Text
  confidence            Float?
  reproductionStatus    String?
  affectedAreas         Json?
  evidenceRefs          Json?
  recommendedNextAction String?  @db.Text
  outboundSummary       String?  @db.Text
  suspectCommits        Json?
  suspectFiles          Json?
  userVisibleImpact     String?  @db.Text
  designNotes           String?  @db.Text
  createdAt             DateTime @default(now())

  workflowRun      WorkflowRun               @relation(fields: [workflowRunId], references: [id])
  deliveryAttempts OutboundDeliveryAttempt[]

  @@index([workflowRunId])
  @@map("findings")
}

// 21. OutboundDestination
model OutboundDestination {
  id              String   @id @default(uuid())
  tenantId        String
  connectorId     String?
  name            String
  destinationType String
  config          Json
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  connector        Connector?                @relation(fields: [connectorId], references: [id])
  routingTargets   RoutingTarget[]
  deliveryAttempts OutboundDeliveryAttempt[]

  @@index([tenantId])
  @@index([connectorId])
  @@map("outbound_destinations")
}

// 22. OutboundDeliveryAttempt
model OutboundDeliveryAttempt {
  id                    String         @id @default(uuid())
  outboundDestinationId String
  workflowRunId         String
  findingId             String?
  status                DeliveryStatus @default(pending)
  payload               Json?
  response              Json?
  errorMessage          String?
  attemptNumber         Int            @default(1)
  createdAt             DateTime       @default(now())

  outboundDestination OutboundDestination @relation(fields: [outboundDestinationId], references: [id])
  workflowRun         WorkflowRun         @relation(fields: [workflowRunId], references: [id])
  finding             Finding?            @relation(fields: [findingId], references: [id])

  @@index([outboundDestinationId])
  @@index([workflowRunId])
  @@index([findingId])
  @@map("outbound_delivery_attempts")
}

// 23. ActionOutput
model ActionOutput {
  id              String           @id @default(uuid())
  tenantId        String
  workflowRunId   String
  outputType      String
  payload         Json
  summary         String?          @db.Text
  visibilityLevel OutputVisibility @default(full)
  payloadRef      String?
  redactionReason String?
  createdAt       DateTime         @default(now())

  workflowRun      WorkflowRun             @relation(fields: [workflowRunId], references: [id])
  deliveryAttempts ActionDeliveryAttempt[]

  @@index([tenantId])
  @@index([workflowRunId])
  @@index([outputType])
  @@map("action_outputs")
}

// 24. ActionDeliveryAttempt
model ActionDeliveryAttempt {
  id                   String               @id @default(uuid())
  tenantId             String
  workflowRunId        String
  actionOutputId       String
  destinationType      String
  destinationId        String?
  status               ActionDeliveryStatus @default(pending)
  attemptNumber        Int                  @default(1)
  externalRef          String?
  placeholderRef       String?
  placeholderRefStatus String?
  response             Json?
  error                String?
  createdAt            DateTime             @default(now())
  completedAt          DateTime?

  workflowRun  WorkflowRun  @relation(fields: [workflowRunId], references: [id])
  actionOutput ActionOutput @relation(fields: [actionOutputId], references: [id])

  @@index([tenantId])
  @@index([workflowRunId])
  @@index([actionOutputId])
  @@index([status])
  @@map("action_delivery_attempts")
}

// 25. ExecutionProfile
model ExecutionProfile {
  id                  String   @id @default(uuid())
  tenantId            String
  key                 String
  displayName         String
  os                  String?
  browserRequired     Boolean  @default(false)
  dockerRequired      Boolean  @default(false)
  androidRequired     Boolean  @default(false)
  macRequired         Boolean  @default(false)
  networkRequirements Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  runtimeProfiles    RuntimeProfile[]
  repositoryMappings RepositoryMapping[]
  workflowScenarios  WorkflowScenario[]
  workflowRuns       WorkflowRun[]

  @@index([tenantId])
  @@map("execution_profiles")
}

// 24. RuntimeProfile
model RuntimeProfile {
  id                 String   @id @default(uuid())
  executionProfileId String
  imageRef           String?
  toolchainConfig    Json?
  createdAt          DateTime @default(now())

  executionProfile ExecutionProfile @relation(fields: [executionProfileId], references: [id])

  @@index([executionProfileId])
  @@map("runtime_profiles")
}

// 25. ExecutionProvider
model ExecutionProvider {
  id                String         @id @default(uuid())
  tenantId          String
  providerType      String
  name              String
  isEnabled         Boolean        @default(true)
  connectionMode    ConnectionMode
  supportedProfiles Json?
  maxConcurrency    Int
  networkZone       String?
  secretRefs        Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  hosts      ExecutionProviderHost[]
  dispatches WorkerDispatch[]

  @@index([tenantId])
  @@map("execution_providers")
}

// 26. ExecutionProviderHost
model ExecutionProviderHost {
  id              String      @id @default(uuid())
  providerId      String
  hostname        String
  os              String?
  capabilities    Json?
  runtimeMode     RuntimeMode
  maxConcurrency  Int
  currentLoad     Int         @default(0)
  isOnline        Boolean     @default(false)
  lastHeartbeatAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  provider   ExecutionProvider      @relation(fields: [providerId], references: [id])
  sessions   ExecutionHostSession[]
  dispatches WorkerDispatch[]

  @@index([providerId])
  @@map("execution_provider_hosts")
}

// 27. ExecutionHostSession
model ExecutionHostSession {
  id              String    @id @default(uuid())
  hostId          String
  sessionToken    String
  connectedAt     DateTime  @default(now())
  disconnectedAt  DateTime?
  lastHeartbeatAt DateTime?
  isActive        Boolean   @default(true)
  metadata        Json?

  host ExecutionProviderHost @relation(fields: [hostId], references: [id])

  @@index([hostId])
  @@map("execution_host_sessions")
}

// 28. RuntimeApiKey
model RuntimeApiKey {
  id              String       @id @default(uuid())
  tenantId        String
  label           String
  keyHash         String
  keyPrefix       String
  runtimeMode     RuntimeMode?
  allowedProfiles Json?
  lastUsedAt      DateTime?
  isDisabled      Boolean      @default(false)
  revokedAt       DateTime?
  createdAt       DateTime     @default(now())

  auditEvents RuntimeApiKeyAuditEvent[]

  @@index([tenantId])
  @@map("runtime_api_keys")
}

// 29. RuntimeApiKeyAuditEvent
model RuntimeApiKeyAuditEvent {
  id              String   @id @default(uuid())
  runtimeApiKeyId String
  action          String
  ipAddress       String?
  metadata        Json?
  createdAt       DateTime @default(now())

  runtimeApiKey RuntimeApiKey @relation(fields: [runtimeApiKeyId], references: [id])

  @@index([runtimeApiKeyId])
  @@map("runtime_api_key_audit_events")
}

// 30. WorkerDispatch
model WorkerDispatch {
  id                   String    @id @default(uuid())
  workflowRunId        String
  executionProviderId  String
  hostId               String?
  workerSharedSecret   String
  jobPayload           Json
  providerJobId        String?
  providerExecutionUrl String?
  status               String
  attemptNumber        Int       @default(1)
  createdAt            DateTime  @default(now())
  startedAt            DateTime?
  completedAt          DateTime?

  workflowRun       WorkflowRun                 @relation(fields: [workflowRunId], references: [id])
  executionProvider ExecutionProvider           @relation(fields: [executionProviderId], references: [id])
  host              ExecutionProviderHost?      @relation(fields: [hostId], references: [id])
  checkpoints       DispatchAttemptCheckpoint[]

  @@index([workflowRunId])
  @@index([executionProviderId])
  @@index([hostId])
  @@map("worker_dispatches")
}

model DispatchAttemptCheckpoint {
  id                String   @id @default(uuid())
  dispatchAttemptId String
  kind              String
  iteration         Int?
  stageId           String?
  payload           Json
  createdAt         DateTime @default(now())

  dispatchAttempt WorkerDispatch @relation(fields: [dispatchAttemptId], references: [id])

  @@index([dispatchAttemptId, kind])
  @@map("dispatch_attempt_checkpoints")
}

// 31. OrchestrationProfile
model OrchestrationProfile {
  id               String   @id @default(uuid())
  tenantId         String
  key              String
  displayName      String
  modelRoutingMode String?
  claudeRequired   Boolean  @default(false)
  codexRequired    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  versions OrchestrationProfileVersion[]

  @@index([tenantId])
  @@map("orchestration_profiles")
}

model Skill {
  id            String      @id @default(uuid())
  tenantId      String?
  name          String
  role          SkillRole
  description   String
  body          String
  outputSchema  Json?
  contentHash   String
  source        SkillSource
  parentSkillId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([tenantId, name, source])
}

model Executor {
  id               String         @id @default(uuid())
  tenantId         String?
  key              String
  description      String
  yaml             String
  parsed           Json
  contentHash      String
  source           ExecutorSource
  parentExecutorId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([tenantId, key, source])
}

// 32. OrchestrationProfileVersion
model OrchestrationProfileVersion {
  id                     String   @id @default(uuid())
  orchestrationProfileId String
  version                Int
  config                 Json
  createdAt              DateTime @default(now())

  orchestrationProfile OrchestrationProfile @relation(fields: [orchestrationProfileId], references: [id])

  @@index([orchestrationProfileId])
  @@map("orchestration_profile_versions")
}

// 33. PromptManifest
model PromptManifest {
  id          String   @id @default(uuid())
  tenantId    String
  key         String
  displayName String
  version     Int
  content     Json
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@map("prompt_manifests")
}

// 34. ReviewProfile
model ReviewProfile {
  id                  String   @id @default(uuid())
  tenantId            String
  key                 String
  displayName         String
  reviewGoal          String?
  maxRounds           Int      @default(3)
  passThreshold       Float?
  requiresSecondModel Boolean  @default(false)
  requiredArtifacts   Json?
  outputSchema        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  versions   ReviewProfileVersion[]
  promptSets ReviewPromptSet[]
  reviews    WorkflowRunReview[]

  @@index([tenantId])
  @@map("review_profiles")
}

// 35. ReviewProfileVersion
model ReviewProfileVersion {
  id              String   @id @default(uuid())
  reviewProfileId String
  version         Int
  config          Json
  createdAt       DateTime @default(now())

  reviewProfile ReviewProfile @relation(fields: [reviewProfileId], references: [id])

  @@index([reviewProfileId])
  @@map("review_profile_versions")
}

// 36. ReviewPromptSet
model ReviewPromptSet {
  id              String   @id @default(uuid())
  reviewProfileId String
  promptKey       String
  promptTemplate  String   @db.Text
  version         Int
  createdAt       DateTime @default(now())

  reviewProfile ReviewProfile @relation(fields: [reviewProfileId], references: [id])

  @@index([reviewProfileId])
  @@map("review_prompt_sets")
}

