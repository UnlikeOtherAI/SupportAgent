  roundNumber         Int
  input               Json?
  output              Json?
  findings            Json?
  decision            ReviewDecision?
  createdAt           DateTime        @default(now())

  workflowRunReview WorkflowRunReview @relation(fields: [workflowRunReviewId], references: [id])

  @@index([workflowRunReviewId])
  @@map("review_round_outputs")
}

// 39. ReviewEvaluation
model ReviewEvaluation {
  id                  String   @id @default(uuid())
  workflowRunReviewId String
